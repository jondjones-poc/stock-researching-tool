# Database (Supabase Postgres pooler)
SUPABASE_DB_PASSWORD=

# Supabase Auth (Google OAuth)
# Google Client ID + Secret go in Supabase Dashboard → Authentication → Providers → Google
# (NOT in this file — the app talks to Supabase only)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Auth / session
AUTH_ADMIN_EMAILS=you@gmail.com
ALLOWED_AUTH_EMAILS=
AUTH_ALLOWED_ORIGINS=https://YOUR-APP.netlify.app
# Cookie lifetime in days (default 7 for desktop; other app used 365)
AUTH_SESSION_MAX_AGE_DAYS=7

# Local dev only (omit on Render)
FRONTEND_DEV_ORIGIN=http://localhost:3000
# Direct API origin for full-page OAuth nav when frontend/API are split (optional)
NEXT_PUBLIC_AUTH_FLOW_API_ORIGIN=http://localhost:3000

# Keepalive (optional)
KEEPALIVE_SECRET=

# External APIs (existing)
FMP_API_KEY=
FINNHUB_API_KEY=
ETORO_PUBLIC_KEY=
ETORO_PRIVATE_KEY=
ETORO_ACCOUNT_TYPE=real
